#include "BluetoothSerial.h"
#include <Arduino.h>
#include "espshell.h"

// Cria o objeto Bluetooth
BluetoothSerial SerialBT;

void setup() {
  // Inicia a serial física para se comunicar com o seu dispositivo externo
  Serial.begin(115200);
  
  // Inicia o Bluetooth com o nome do dispositivo
  SerialBT.begin("ESP_Shell_Terminal");
  Serial.println("Bluetooth iniciado! Conecte-se e envie comandos.");
}

SHELL_USER_HANDLER(argc, argv) {

    if (argc > 1)
      Serial.printf("Hello, %s!\r\n", argv[1]);
    else
      Serial.printf("Hello, World!\r\n");
    return 0;
}

// Setup terminal
//
void setup() {
  Serial.begin(115200);

  // Let espshell fully start before printing banners
  delay(2000); 

  Serial.println(" ------ misc command demo -----");

  Serial.println(" type \"misc\" and press Enter or");
  Serial.println(" type \"misc SomeText\" and press Enter");
}

void loop() {
  // Lê o que vem do terminal Bluetooth e envia para a Serial Física (RX/TX)
  if (SerialBT.available()) {
    Serial.write(SerialBT.read());
  }
  
  // Lê o que vem da Serial Física e envia de volta para o terminal Bluetooth
  if (Serial.available()) {
    SerialBT.write(Serial.read());
  }
    delay(9999);
}
